<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DreamHome_Mobile_SQLite.Pages.ClientViewingsPage"
             xmlns:local="clr-namespace:DreamHome_Mobile_SQLite.Models"
             Title="Client Viewings">
    <VerticalStackLayout
       Padding="15,0"
       Spacing="15">
        <Label
            Text="List the names of all clients who have viewed a property, along with any comments supplied."
            FontSize="16"
            FontAttributes="Bold" />


        <Label
               Text="Results:"
               FontAttributes="Bold"
               Margin="0,10,0,0" />

        <ScrollView>
            <CollectionView x:Name="ClientCollectionView" ItemsSource="{Binding ClientViewingsList}">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="0.9*,0.9*,0.9*,1.2*,1.2*" Padding="8" BackgroundColor="CornflowerBlue">
                        <Label Text="ClientNo" FontAttributes="Bold" Grid.Column="0"/>
                        <Label Text="FName" FontAttributes="Bold" Grid.Column="1" />
                        <Label Text="LName" FontAttributes="Bold" Grid.Column="2"/>
                        <Label Text="PropertyNo" FontAttributes="Bold" Grid.Column="3"/>
                        <Label Text="Comment" FontAttributes="Bold" Grid.Column="4"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ClientViewing">
                        <Grid ColumnDefinitions="0.9*,0.9*,0.9*,1.2*,1.2*" Padding="8">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFFFFF" />
                                </DataTrigger>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="False">
                                    <Setter Property="BackgroundColor" Value="LightSkyBlue" />
                                </DataTrigger>
                            </Grid.Triggers>

                            <Label Text="{Binding ClientNo}" Grid.Column="0"/>
                            <Label Text="{Binding FName}" Grid.Column="1"/>
                            <Label Text="{Binding LName}" Grid.Column="2"/>
                            <Label Text="{Binding PropertyNo}" Grid.Column="3"/>
                            <Label Text="{Binding Comment}" Grid.Column="4" />
                            
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>