<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DreamHome_Mobile_SQLite.Pages.AddStaffDetailsPage"
             xmlns:local="clr-namespace:DreamHome_Mobile_SQLite.Models"
             Title="Add Staff Details">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="14">


            <Label Text="Staff Number" FontAttributes="Bold" />
            <Entry
                x:Name="StaffNoEntry"
                Placeholder="e.g. SG99"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="First Name" FontAttributes="Bold" />
            <Entry
                x:Name="FNameEntry"
                Placeholder="Enter first name"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="Last Name" FontAttributes="Bold" />
            <Entry
                x:Name="LNameEntry"
                Placeholder="Enter last name"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="Position" FontAttributes="Bold" />
            <Picker x:Name="PositionPicker" Title="Select position" SelectedItem="Assistant">
                <Picker.Items>
                    <x:String>Manager</x:String>
                    <x:String>Deputy</x:String>
                    <x:String>Supervisor</x:String>
                    <x:String>Assistant</x:String>
                    <x:String>Administrator</x:String>
                    <x:String>Sales Agent</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Date of Birth" FontAttributes="Bold" />
            <Entry
                x:Name="DobEntry"
                Placeholder="yyyy-MM-dd"
                Keyboard="Text"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="Salary" FontAttributes="Bold" />
            <Entry
                x:Name="SalaryEntry"
                Placeholder="e.g. 30000"
                Keyboard="Numeric"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="Branch Number" FontAttributes="Bold" />
            <Picker
                x:Name="BranchPicker"
                Title="Select branch" 
                SelectedItem="B002"/>

            <HorizontalStackLayout
                Spacing="15"
                HorizontalOptions="Center"
                Margin="0,20,0,0">

                <Button
                    x:Name="SaveButton"
                    Text="Save"
                    Clicked="OnSaveClicked"
                    WidthRequest="120"
                    BackgroundColor="CornflowerBlue" />

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>