<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DreamHome_Mobile_SQLite.Pages.PropertyStaffCountPage"
             xmlns:local="clr-namespace:DreamHome_Mobile_SQLite.Models"
             Title="Property Staff Counts">

    <VerticalStackLayout
           Padding="15,0"
           Spacing="25">

        <Label
            Text="Find the number of properties handled by each staff member, along with the branch number of the member of staff."
            FontSize="16"
            FontAttributes="Bold" />    


        <Label
       Text="Results:"
       FontAttributes="Bold"
       Margin="0,10,0,0" />

        <ScrollView>
            <CollectionView x:Name="PropertyCollectionView" ItemsSource="{Binding BranchStaffList}">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*,*,*" Padding="8" BackgroundColor="CornflowerBlue">
                        <Label Text="BranchNo" FontAttributes="Bold" Grid.Column="0"/>
                        <Label Text="StaffNo" FontAttributes="Bold" Grid.Column="1" />
                        <Label Text="Count" FontAttributes="Bold" Grid.Column="2"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:BranchStaffCount">
                        <Grid ColumnDefinitions="*,*,*" Padding="8">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFFFFF" />
                                </DataTrigger>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="False">
                                    <Setter Property="BackgroundColor" Value="LightSkyBlue" />
                                </DataTrigger>
                            </Grid.Triggers>

                            <Label Text="{Binding BranchNo}" Grid.Column="0"/>
                            <Label Text="{Binding StaffNo}" Grid.Column="1"/>
                            <Label Text="{Binding MyCount}" Grid.Column="2"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </VerticalStackLayout>

</ContentPage>