<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DreamHome_Mobile_SQLite.Pages.StaffCityPage"
             xmlns:local="clr-namespace:DreamHome_Mobile_SQLite.Models"
             Title="Staff in City">

    <VerticalStackLayout
       Padding="15,0"
       Spacing="25">
        <Label
               Text="Find all staff who work in a given city."
               FontSize="16" 
               FontAttributes="Bold"/>

        <Label
               Text="Enter city:"
               FontAttributes="Italic" />

        <Entry
               x:Name="CityEntry"
               Keyboard="Text" />

        <Button
               Text="Run Query"
               Clicked="OnRunQueryClicked"
               HorizontalOptions="Center"
               WidthRequest="200"
               HeightRequest="25" 
               BackgroundColor="CornflowerBlue"/>

        <Label
               Text="Results:"
               FontAttributes="Bold"
               Margin="0,10,0,0" />

        <ScrollView>
            <CollectionView x:Name="StaffCollectionView" ItemsSource="{Binding StaffCityList}" IsVisible="False">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*,*,*,*" Padding="8" BackgroundColor="CornflowerBlue">
                        <Label Text="StaffNo" FontAttributes="Bold" Grid.Column="0"/>
                        <Label Text="FName" FontAttributes="Bold" Grid.Column="1" />
                        <Label Text="LName" FontAttributes="Bold" Grid.Column="2"/>
                        <Label Text="Position" FontAttributes="Bold" Grid.Column="3"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:CityStaff">
                        <Grid ColumnDefinitions="*,*,*,*" Padding="8">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFFFFF" />
                                </DataTrigger>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="False">
                                    <Setter Property="BackgroundColor" Value="LightSkyBlue" />
                                </DataTrigger>
                            </Grid.Triggers>

                            <Label Text="{Binding StaffNo}" Grid.Column="0"/>
                            <Label Text="{Binding FName}" Grid.Column="1"/>
                            <Label Text="{Binding LName}" Grid.Column="2"/>
                            <Label Text="{Binding Position}" Grid.Column="3"/>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </VerticalStackLayout>

</ContentPage>