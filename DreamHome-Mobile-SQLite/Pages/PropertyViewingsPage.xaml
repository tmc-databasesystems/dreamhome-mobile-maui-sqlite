<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DreamHome_Mobile_SQLite.Pages.PropertyViewingsPage"
             xmlns:local="clr-namespace:DreamHome_Mobile_SQLite.Models"
             Title="Property Viewings">
    <VerticalStackLayout
       Padding="15,0"
       Spacing="15">
        <Label
            Text="Get a list of properties viewed between the given start and end dates."
            FontSize="16"
            FontAttributes="Bold" />

        <Label
            Text="Select start date:"
            FontAttributes="Italic" />

        <DatePicker
            x:Name="StartDatePicker"
            Format="yyyy-MM-dd"
            MaximumDate="12/31/2100" />

        <Label
            Text="Select end date:"
            FontAttributes="Italic" />

        <DatePicker
            x:Name="EndDatePicker"
            Format="yyyy-MM-dd"
            MaximumDate="12/31/2100" />

        <Button
            Text="Run Query"
            Clicked="OnRunQueryClicked"
            HorizontalOptions="Center"
            WidthRequest="200"
            HeightRequest="40"
            BackgroundColor="CornflowerBlue" />

        <Label
               Text="Results:"
               FontAttributes="Bold"
               Margin="0,10,0,0" />
        
        <ScrollView>
            <CollectionView x:Name="ViewingCollectionView" ItemsSource="{Binding PropertyViewingList}" IsVisible="False">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="*,*,*,*" Padding="8" BackgroundColor="CornflowerBlue">
                        <Label Text="ClientNo" FontAttributes="Bold" Grid.Column="0"/>
                        <Label Text="PropertyNo" FontAttributes="Bold" Grid.Column="1" />
                        <Label Text="ViewDate" FontAttributes="Bold" Grid.Column="2"/>
                        <Label Text="Comment" FontAttributes="Bold" Grid.Column="3"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:Viewing">
                        <Grid ColumnDefinitions="*,*,*,*" Padding="8">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFFFFF" />
                                </DataTrigger>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="False">
                                    <Setter Property="BackgroundColor" Value="LightSkyBlue" />
                                </DataTrigger>
                            </Grid.Triggers>

                            <Label Text="{Binding ClientNo}" Grid.Column="0"/>
                            <Label Text="{Binding PropertyNo}" Grid.Column="1"/>
                            <Label Text="{Binding ViewDate, StringFormat='{0:yyyy-MM-dd}'}" Grid.Column="2"/>
                            <Label Text="{Binding Comments}" Grid.Column="3"/>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </VerticalStackLayout>

</ContentPage>